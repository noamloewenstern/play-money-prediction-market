# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="playmoney"
POSTGRES_PORT="5432"

# For local dev, use localhost. Docker Compose overrides these automatically.
POSTGRES_PRISMA_URL="postgresql://postgres:password@localhost:5432/playmoney?schema=public"
POSTGRES_URL_NON_POOLING="postgresql://postgres:password@localhost:5432/playmoney?schema=public"

# ── Auth (NextAuth.js) ───────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # Required. Generate via: openssl rand -base64 32

# Optional. Magic link login via Resend. Leave empty to use password-only auth.
AUTH_RESEND_KEY=""
AUTH_RESEND_EMAIL=""

# Optional. Comma-separated list of allowed emails. Empty = open registration.
AUTH_EMAIL_WHITELIST=""

# ── Docker only ──────────────────────────────────────────────────────────────
# Used by the web container to reach the API container during SSR.
# Not needed for local dev. Docker Compose sets this automatically.
# INTERNAL_API_URL="http://api:3001"

# ── Docker prod ports ────────────────────────────────────────────────────────
# Host ports for web and api containers (external proxy routes domains here).
# WEB_PORT="3000"
# API_PORT="3001"

# ── Cron / Background Jobs ──────────────────────────────────────────────────
CRON_SECRET="" # Secret for authenticating cron job requests. Generate via: openssl rand -base64 32

# ── Optional ─────────────────────────────────────────────────────────────────
DEV_DB_SEED_EMAIL="" # Set your email for the DB seed to add data to your user account
OPENAI_API_KEY=""    # Set OpenAI key to auto-generate question tags
BLOB_READ_WRITE_TOKEN="" # Set vercel blob write token for avatar uploads