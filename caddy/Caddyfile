:80 {
	log {
		output stdout
		format console
	}

	# NextAuth routes — must go to web, not api
	handle /api/auth/* {
		reverse_proxy web:3000
	}

	# API routes
	handle /api/* {
		reverse_proxy api:3001
	}
	handle /v1/* {
		reverse_proxy api:3001
	}

	# Everything else → web
	handle {
		reverse_proxy web:3000
	}
}
